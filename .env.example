# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Server-only (recommended for API writes): Supabase Dashboard → Settings → API → secret key
SUPABASE_SERVICE_ROLE_KEY=

# AI (stub = default, no key needed)
AI_PROVIDER=stub

# In-memory store for local/e2e without Supabase (set by npm run e2e)
# USE_IN_MEMORY=1
CURSOR_API_KEY=crsr_...
CURSOR_MODEL_ID=composer-2.5

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://localhost:3000
